# GTM Engine - Environment Template
# Copy to .env and fill in your keys. Never commit .env.

# Apollo (prospecting + enrichment)
# Get from: https://app.apollo.io/#/settings/integrations/api_keys
APOLLO_API_KEY=

# Attio (CRM)
# Connected via MCP - no API key needed if using Claude MCP integration
# If using REST fallback:
ATTIO_API_KEY=

# HeyReach (LinkedIn sequencing — default activation channel)
# Connected via MCP — set the API key in the HeyReach MCP server config
HEYREACH_API_KEY=

# Smartlead (email sequencing — optional)
# Get from: https://app.smartlead.ai/settings/api
SMARTLEAD_API_KEY=

# Optional: Clay (additional enrichment)
# Connected via MCP - no API key needed if using Claude MCP integration
